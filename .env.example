# ─── Amazon Affiliate (Associates) ────────────────────────────────────────────
# Your Amazon Associates tag (e.g. yourname-20)
# Get it from https://affiliate-program.amazon.com/
# When set, all Amazon product URLs will be built as:
#   https://www.amazon.com/dp/{ASIN}/?tag=AMAZON_ASSOCIATE_TAG
AMAZON_ASSOCIATE_TAG=mbtechdeals-20

# ─── Bot Behaviour ─────────────────────────────────────────────────────────────
# Set to true to preview tweets without publishing
DRY_RUN=true

# Affiliate disclosure appended to every tweet (required by FTC / Amazon ToS)
AFFILIATE_DISCLOSURE=#ad

# Cron schedule for automatic posting (server local time)
# Examples:
#   0 10 * * *    → every day at 10:00 AM
#   0 */6 * * *   → every 6 hours
#   0 9,17 * * *  → twice a day at 09:00 and 17:00
POST_SCHEDULE=0 10 * * *

# ─── Retry Settings ────────────────────────────────────────────────────────────
POST_MAX_RETRIES=5
POST_RETRY_BASE_DELAY_MS=1500
POST_RETRY_MAX_DELAY_MS=30000
POST_RETRY_JITTER_MS=500

# ─── Niche Selector ────────────────────────────────────────────────────────────
# Leave blank to pick from ALL niches randomly.
# Allowed values: Tech | Fitness | Crypto | Web3 | Home
# PRODUCT_NICHE=Tech

# ─── Queue Storage ─────────────────────────────────────────────────────────────
# Path for failed tweet queue (default: ./queue/failed-tweets.json)
# QUEUE_FILE_PATH=./queue/failed-tweets.json

# ─── UTM Tracking (non-Amazon links) ──────────────────────────────────────────
# Applied only when AMAZON_ASSOCIATE_TAG is NOT set or product has no ASIN.
UTM_SOURCE=x
UTM_MEDIUM=social
UTM_CAMPAIGN=affiliate_daily_deals
UTM_CONTENT_PREFIX=deal

# ─── Discord (optional) ───────────────────────────────────────────────────────
# Create a webhook: Discord channel → Edit → Integrations → Webhooks → New Webhook
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/1481148234305896558/fTelO1bQIID4tMx1milu8LyNjEMe8to7K79SOj7kY6BqxSrerQj9fj5Yiuu8jrUXEkvd
# DISCORD_BOT_NAME=Deals Bot

# ─── Telegram (optional) ──────────────────────────────────────────────────────
# 1. Create a bot via @BotFather → get token
# 2. Add the bot to your channel/group as admin
# 3. Get chat ID: https://api.telegram.org/bot<TOKEN>/getUpdates
#    OR for public channel: @your_channel_name (e.g. @mydeals)
# TELEGRAM_BOT_TOKEN=7146135778:AAHfKnfkeMx3fTRraWCmluzKjce9bbdixgg
# TELEGRAM_CHAT_ID=-1001234567890

# ─── X / Twitter (disable posting to X) ───────────────────────────────────────
# Set to false if you only want Discord/Telegram and not X
# POST_TO_X=true

# ─── Web3 Job Alerts — UNUSUAL MONEY-MAKER 💰 ────────────────────────────────
# FREE  channel → 1 job/day (no salary, link to your site)
# PREMIUM channel → 3–5 jobs/day (salary shown, direct apply link)
# Charge $9.99/month for Premium via Telegram Stars or Gumroad
#
# To create a Premium channel:
#   1. Create a new Telegram channel
#   2. Add @WhHisBot as admin
#   3. Get its Chat ID (same method as above)
#   4. Set TELEGRAM_PREMIUM_CHAT_ID below
#
# TELEGRAM_PREMIUM_CHAT_ID=-1001987654321
# DISCORD_PREMIUM_WEBHOOK_URL=https://discord.com/api/webhooks/PREMIUM_ID/TOKEN
#
# Number of jobs per run for Premium (default: 3)
# JOBS_PREMIUM_LIMIT=3
#
# Separate cron schedule for job alerts (default: uses POST_SCHEDULE)
# JOBS_SCHEDULE=0 9 * * *

# ─── Sponsored Job Posts — ZERO-COST MONETIZATION 💰 ─────────────────────────
#
# Companies PAY YOU to have their job pinned at the TOP of every daily alert
# with a "🔥 SPONSORED" badge visible to all your Telegram & Discord followers.
#
# PRICING TIERS (charge companies directly):
#   🥉 Basic    $19.99 / week  — 1 platform (Telegram OR Discord)
#   🥈 Standard $34.99 / week  — both platforms
#   🥇 Premium  $59.99 / week  — both platforms + X (Twitter) shoutout
#
# HOW TO GET YOUR FIRST SPONSOR (copy-paste outreach):
# ─────────────────────────────────────────────────────
# 1. Find Web3 companies posting jobs on LinkedIn / AngelList / RemoteOK
# 2. DM their HR / Founder:
#
#    Subject: Reach 500+ Web3 devs for $19.99/week
#
#    Hi [Name],
#    I run a Web3 job alert bot that posts daily to Telegram + Discord.
#    For $19.99/week your job is pinned at the TOP of every alert with
#    a direct apply link. Interested?
#
# 3. Once they pay (PayPal / crypto), run: npm run sponsor:add
# 4. Their job appears automatically in the next scheduled post.
#
# COMMANDS:
#   npm run sponsor:list   → view all sponsors + revenue stats
#   npm run sponsor:add    → add a new paying sponsor (interactive)
#   npm run sponsor:post   → post sponsored jobs now (Telegram + Discord)
#   npm run sponsor:dry    → preview sponsored post without sending
#   npm run sponsor:stats  → revenue summary only
#
# No extra env vars needed — uses existing TELEGRAM_BOT_TOKEN,
# TELEGRAM_CHAT_ID and DISCORD_WEBHOOK_URL configured above.
# Sponsor data lives in src/data/sponsors.json (edit directly or via CLI).

# ─── Remote Product Source (optional) ─────────────────────────────────────────
# Supports: direct array [ {...product} ]
# or object payload { "products": [ {...product} ] }
# PRODUCT_SOURCE_URL=https://your-domain.com/api/products
# PRODUCT_SOURCE_API_KEY=your_api_key_if_required
